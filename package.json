{
  "name": "lovart-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -H 0.0.0.0",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "graphify:local": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/graphify_local_build.ps1 -Root .",
    "qa:canvas:all": "node scripts/canvas_qa.mjs",
    "qa:canvas:layers": "node scripts/canvas_qa_layers.mjs",
    "qa:canvas:media": "node scripts/canvas_qa_media.mjs",
    "qa:canvas:frame": "node scripts/canvas_qa_canvas.mjs",
    "qa:canvas:projects": "node scripts/canvas_qa_projects.mjs",
    "qa:canvas:settings": "node scripts/canvas_qa_settings.mjs",
    "qa:canvas:persistence": "node scripts/canvas_qa_canvas_persistence.mjs",
    "qa:canvas:autolayout": "node scripts/canvas_qa_autolayout.mjs",
    "qa:canvas:benchmark": "node scripts/canvas_qa_benchmark.mjs",
    "qa:canvas:scenarios": "npm run qa:canvas:layers && npm run qa:canvas:media && npm run qa:canvas:frame && npm run qa:canvas:projects && npm run qa:canvas:settings && npm run qa:canvas:persistence"
  },
  "dependencies": {
    "lucide-react": "^0.554.0",
    "next": "16.0.10",
    "rbush": "^4.0.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.25",
    "@types/rbush": "^4.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "baseline-browser-mapping": "^2.10.7",
    "eslint": "^9",
    "eslint-config-next": "16.0.3",
    "playwright": "^1.58.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.3"
  }
}
